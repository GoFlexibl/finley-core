{
  "name": "@goflexibl/finley-core",
  "version": "0.2.1",
  "description": "Shared Finley (talk-to-your-data assistant) core: types, value formatters, API client factory, follow-ups, the FinleyDataRender component, and the designed-card framework (FinleyBlocks + FINLEY_SKIN). Single source of truth consumed by both the admin portal and the customer app.",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mui/icons-material": "^5.11.0",
    "@mui/material": "^5.11.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "^3.0.0"
  },
  "devDependencies": {
    "@mui/icons-material": "^5.11.9",
    "@mui/material": "^5.11.10",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "recharts": "^3.5.1",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
